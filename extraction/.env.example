# Copy this file to .env and fill in your values
# Never commit .env — it is gitignored

# HuggingFace NER model to use
# Default: d4data/biomedical-ner-all (downloads automatically on first run)
NER_MODEL_NAME=d4data/biomedical-ner-all

# Maximum upload file size in MB
MAX_FILE_SIZE_MB=10

# Compute device: "cpu" or "cuda"
# Use "cuda" only if you have an NVIDIA GPU with CUDA drivers installed
DEVICE=cpu
